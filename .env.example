# ── Required: Supabase waitlist storage ──────────────────
NEXT_PUBLIC_SUPABASE_URL='https://<project-id>.supabase.co'
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY='sb_publishable_<public-key>'
SUPABASE_TABLE="waitlist"

# ── Optional: Resend email (omit to disable emails) ──────
RESEND_API_KEY=""

# ── Optional: Upstash rate-limiting (omit to disable) ────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Site / Brand ─────────────────────────────────────────
NEXT_PUBLIC_SITE_NAME="Insprii"
NEXT_PUBLIC_SITE_DESCRIPTION="Save your inspo from Instagram, Pinterest, or anywhere — and discover exactly what your style is trying to tell you."
NEXT_PUBLIC_SITE_URL="https://insprii.com"

# ── Social (leave blank to hide) ─────────────────────────
NEXT_PUBLIC_CONTACT_EMAIL=""
NEXT_PUBLIC_TWITTER_URL=""
NEXT_PUBLIC_GITHUB_URL=""
NEXT_PUBLIC_REDDIT_URL=""

# ── Email customisation ──────────────────────────────────
EMAIL_FROM="noreply@example.com"
EMAIL_FROM_NAME="My App"
EMAIL_REPLY_TO=""
EMAIL_SUBJECT="Thanks for joining our waitlist! 🎉"
EMAIL_LOGO_URL=""
