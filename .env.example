# Since .env is gitignored, you can use .env.example to build a new `.env` file when you clone the repo.
# Keep this file up-to-date when you add new variables to `.env`.
#
# This file will be committed to version control, so make sure not to have any secrets in it.
# If you are cloning this repo, create a copy of this file named `.env` and populate it with your secrets.

# --- Database ---
# Supabase Postgres transaction pooler (port 6543). Replace [USERNAME], [PASSWORD], and the region.
POSTGRES_URL="postgres://postgres.[USERNAME]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?workaround=supabase-pooler.vercel"

# --- Better Auth ---
# Base URL of your Better Auth instance (change according to enviroment, e.g. staging vs production)
BETTER_AUTH_URL='http://localhost:3000'
# Generate via: openssl rand -base64 32
# @see https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET='supersecret'


# Preconfigured Google OAuth provider
# @see https://better-auth.com/docs/authentication/google
GOOGLE_CLIENT_ID=''
GOOGLE_CLIENT_SECRET=''

# --- Site metadata (used by the Next.js landing page and welcome email) ---
NEXT_PUBLIC_SITE_NAME=
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_SITE_DESCRIPTION=

# --- Waitlist email (optional — leave RESEND_API_KEY blank to skip emails) ---
# @see https://resend.com
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_FROM_NAME=
EMAIL_REPLY_TO=
EMAIL_SUBJECT=
EMAIL_LOGO_URL=

# --- Waitlist rate limit (optional — required if RESEND_API_KEY is set) ---
# @see https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Expo / EAS (optional — set when you wire the mobile app to EAS) ---
EAS_PROJECT_ID=
# iOS Google Sign-In: create an iOS OAuth client in Google Console, then paste the reversed client ID (looks like com.googleusercontent.apps.XXXXX)
GOOGLE_IOS_REVERSED_CLIENT_ID=
